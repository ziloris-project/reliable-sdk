{
    "name": "@reliableapp/react",
    "version": "1.2.0",
    "description": "React bindings for Reliable — Provider, ErrorBoundary with component stacks, hooks, and router adapters. Re-exports the full core SDK.",
    "license": "Apache-2.0",
    "homepage": "https://github.com/ziloris-project/reliable-sdk/tree/main/react#readme",
    "bugs": {
        "url": "https://github.com/ziloris-project/reliable-sdk/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ziloris-project/reliable-sdk.git",
        "directory": "react"
    },
    "author": {
        "name": "Ziloris",
        "url": "https://ziloris.com"
    },
    "keywords": [
        "react",
        "reactjs",
        "nextjs",
        "react-error-boundary",
        "observability",
        "error-tracking",
        "session-replay",
        "monitoring",
        "reliable",
        "ziloris"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "dependencies": {
        "@reliableapp/frontend-core": "^1.2.0"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "react": "^18.2.0"
    }
}
