{
    "name": "@reliableapp/frontend-core",
    "version": "1.0.9",
    "description": "Reliable browser SDK — framework-agnostic core (errors, vitals, network, clicks, navigation, replay). Built by Ziloris · https://ziloris.com",
    "homepage": "https://reliable.ziloris.com/docs",
    "bugs": {
        "url": "https://reliable.ziloris.com/docs"
    },
    "author": {
        "name": "Ziloris",
        "url": "https://ziloris.com"
    },
    "keywords": [
        "observability",
        "error-tracking",
        "session-replay",
        "web-vitals",
        "browser-sdk",
        "monitoring",
        "analytics",
        "reliable",
        "ziloris"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "pako": "^2.1.0",
        "rrweb": "^2.0.0-alpha.20",
        "web-vitals": "^4.2.4"
    },
    "devDependencies": {
        "@types/pako": "^2.0.4",
        "tsup": "^8.5.1",
        "typescript": "~5.7.0"
    }
}
