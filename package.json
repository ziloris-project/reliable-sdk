{
    "name": "@reliable/sdk",
    "version": "0.0.0",
    "private": true,
    "description": "Reliable browser SDK monorepo (core + framework bindings)",
    "license": "Apache-2.0",
    "homepage": "https://github.com/ziloris-project/reliable-sdk#readme",
    "bugs": {
        "url": "https://github.com/ziloris-project/reliable-sdk/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ziloris-project/reliable-sdk.git"
    },
    "author": {
        "name": "Ziloris",
        "url": "https://ziloris.com"
    },
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "build": "pnpm -r build",
        "dev": "pnpm -r --parallel dev",
        "typecheck": "pnpm -r typecheck",
        "clean": "pnpm -r clean",
        "changeset": "changeset",
        "version": "changeset version && pnpm install --lockfile-only",
        "release": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "tsup": "^8.3.0",
        "typescript": "^5.5.4"
    }
}
